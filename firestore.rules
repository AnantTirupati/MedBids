rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the authenticated user is an admin
    // In Supabase/Supabase-like architecture, metadata or a roles collection determines this.
    // For Firestore, we check if the user document in the users collection has role == 'admin'
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if the request matches the user's own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for USERS collection (Patients profiles)
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // Rules for PHARMACIES collection (Pharmacy profiles)
    match /pharmacies/{pharmacyId} {
      allow read: if isAuthenticated(); // Authenticated users can view pharmacy profiles
      allow write: if isOwner(pharmacyId) || isAdmin();
    }
    
    // Rules for PRESCRIPTIONS collection
    match /prescriptions/{prescriptionId} {
      allow read: if isAuthenticated() && (
        resource.data.patient_id == request.auth.uid || 
        isAdmin() || 
        // Allow verified pharmacies to view prescription items of live auctions
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pharmacy' && resource.data.status == 'auction_live')
      );
      allow create: if isAuthenticated() && request.resource.data.patient_id == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.patient_id == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Rules for AUCTIONS collection
    match /auctions/{auctionId} {
      allow read: if isAuthenticated(); // Anyone authenticated can view auctions
      allow create: if isAuthenticated() && (
        request.resource.data.patient_id == request.auth.uid || 
        request.resource.data.prescription.patient_id == request.auth.uid || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.patient_id == request.auth.uid ||
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'pharmacy' &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.end_time == resource.data.end_time
        ) ||
        isAdmin()
      );
    }
    
    // Rules for BIDS collection
    match /bids/{bidId} {
      allow read: if isAuthenticated() && (
        resource.data.pharmacy_id == request.auth.uid ||
        resource.data.patient_id == request.auth.uid ||
        isAdmin()
      );
      // Pharmacies can place and modify only their own bids
      allow create: if isAuthenticated() && (
        (request.resource.data.pharmacy_id == request.auth.uid && 
         get(/databases/$(database)/documents/auctions/$(request.resource.data.auction_id)).data.status == 'live') ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        (resource.data.pharmacy_id == request.auth.uid && 
         request.resource.data.pharmacy_id == request.auth.uid &&
         get(/databases/$(database)/documents/auctions/$(resource.data.auction_id)).data.status == 'live') ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Rules for OFFERS collection
    match /offers/{offerId} {
      allow read: if isAuthenticated() && (
        resource.data.pharmacy_id == request.auth.uid ||
        resource.data.patient_id == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAuthenticated() && (
        resource.data.pharmacy_id == request.auth.uid ||
        resource.data.patient_id == request.auth.uid ||
        isAdmin()
      );
    }
    
    // Rules for RESERVATIONS collection
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && (
        resource.data.pharmacy_id == request.auth.uid ||
        resource.data.patient_id == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAuthenticated() && (
        resource.data.pharmacy_id == request.auth.uid ||
        isAdmin()
      );
    }
    
    // Rules for NOTIFICATIONS collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated(); // Services or other users can trigger notifications
    }
    
    // Rules for VERIFICATION REQUESTS collection
    match /verification_requests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.pharmacy_id == request.auth.uid ||
        isAdmin()
      );
      allow create, update: if isAuthenticated() && (
        request.resource.data.pharmacy_id == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Rules for SETTINGS collection
    match /settings/{settingId} {
      allow read: if isAuthenticated(); // Anyone authenticated can read global settings
      allow write: if isAdmin(); // Only admins can change system settings
    }

    // Rules for AUDIT LOGS collection (Immutable write-once, read-only by admin)
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Rules for NOTIFICATION PREFERENCES collection
    match /notification_preferences/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Rules for DEVICE TOKENS collection
    match /device_tokens/{tokenId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
